
.page.data-v-dcb1f0d8 {
  min-height: 100vh;
  padding: 24rpx 24rpx 160rpx;
  background: #f6f7fb;
  box-sizing: border-box;
}
.form-card.data-v-dcb1f0d8 {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(32, 37, 43, 0.05);
}
.section-head.data-v-dcb1f0d8 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.section-title.data-v-dcb1f0d8 {
  display: block;
  margin-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2329;
}
.section-head .section-title.data-v-dcb1f0d8 {
  margin-bottom: 0;
}
.section-tip.data-v-dcb1f0d8 {
  font-size: 24rpx;
  color: #8a8f99;
}
.search-bar.data-v-dcb1f0d8 {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.search-input.data-v-dcb1f0d8 {
  flex: 1;
  height: 84rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: #f7f8fb;
  font-size: 28rpx;
  color: #222222;
  box-sizing: border-box;
}
.search-btn.data-v-dcb1f0d8 {
  margin: 0;
  width: 140rpx;
  height: 84rpx;
  line-height: 84rpx;
  border: none;
  border-radius: 16rpx;
  background: #d96c3a;
  font-size: 28rpx;
}
.search-btn.data-v-dcb1f0d8::after,
.save-btn.data-v-dcb1f0d8::after {
  border: none;
}
.search-result-list.data-v-dcb1f0d8 {
  margin-top: 20rpx;
  border: 2rpx solid #f1f3f6;
  border-radius: 20rpx;
  overflow: hidden;
}
.search-result-item.data-v-dcb1f0d8 {
  padding: 22rpx 24rpx;
  border-bottom: 2rpx solid #f1f3f6;
}
.search-result-item.data-v-dcb1f0d8:last-child {
  border-bottom: none;
}
.result-title.data-v-dcb1f0d8 {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #1f2329;
}
.result-address.data-v-dcb1f0d8 {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7a818d;
}
.map-wrapper.data-v-dcb1f0d8 {
  position: relative;
  margin-top: 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
}
.map.data-v-dcb1f0d8 {
  width: 100%;
  height: 360rpx;
}
.map-center-pin.data-v-dcb1f0d8 {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 48rpx;
  height: 48rpx;
  margin-left: -24rpx;
  margin-top: -24rpx;
  border-radius: 50%;
  background: rgba(217, 108, 58, 0.95);
  color: #ffffff;
  font-size: 34rpx;
  line-height: 48rpx;
  text-align: center;
  pointer-events: none;
  box-shadow: 0 8rpx 20rpx rgba(217, 108, 58, 0.25);
}
.selected-location.data-v-dcb1f0d8 {
  margin-top: 18rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: #fff5ee;
}
.selected-location-label.data-v-dcb1f0d8 {
  display: block;
  font-size: 24rpx;
  color: #b85d33;
}
.selected-location-text.data-v-dcb1f0d8 {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #4f5662;
}
.form-item.data-v-dcb1f0d8,
.switch-item.data-v-dcb1f0d8 {
  margin-bottom: 24rpx;
}
.form-item.data-v-dcb1f0d8:last-child,
.switch-item.data-v-dcb1f0d8:last-child {
  margin-bottom: 0;
}
.label.data-v-dcb1f0d8 {
  display: block;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  color: #1f2329;
}
.input.data-v-dcb1f0d8,
.picker-value.data-v-dcb1f0d8,
.textarea.data-v-dcb1f0d8 {
  width: 100%;
  border-radius: 16rpx;
  background: #f7f8fb;
  font-size: 28rpx;
  color: #222222;
  box-sizing: border-box;
}
.input.data-v-dcb1f0d8,
.picker-value.data-v-dcb1f0d8 {
  height: 84rpx;
  line-height: 84rpx;
  padding: 0 24rpx;
}
.picker-placeholder.data-v-dcb1f0d8 {
  color: #9aa1ad;
}
.textarea.data-v-dcb1f0d8 {
  min-height: 168rpx;
  padding: 22rpx 24rpx;
}
.switch-item.data-v-dcb1f0d8 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}
.switch-item .label.data-v-dcb1f0d8 {
  margin-bottom: 0;
}
.bottom-bar.data-v-dcb1f0d8 {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -8rpx 24rpx rgba(32, 37, 43, 0.06);
  box-sizing: border-box;
}
.save-btn.data-v-dcb1f0d8 {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border: none;
  border-radius: 999rpx;
  background: #d96c3a;
  font-size: 30rpx;
  font-weight: 500;
}
